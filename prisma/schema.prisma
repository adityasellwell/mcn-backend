generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Status {
  ACTIVE
  INACTIVE
  PENDING
}

enum ChapterRoleType {
  PRESIDENT
  VICE_PRESIDENT
  TREASURER
  SECRETARY
}

enum VisitorSource {
  ADMIN
  MEMBER
  WEBSITE
}

enum VisitorStatus {
  LEAD
  INVITED
  REGISTERED
  PAYMENT_SUBMITTED
  PAID
  ATTENDED
  CONVERTED
  REJECTED
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum RegistrationType {
  MEMBER
  GUEST
  VISITOR
  OTHER
}

enum ReferralStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model RegistrationApplication {
  id Int @id @default(autoincrement())

  registrationType RegistrationType

  chapterName String?

  chapterId Int?                
  chapter   Chapter? @relation(fields: [chapterId], references: [id])

  fullName String

  mobile String

  email String

  companyName String

  businessCategory String

  website String?
 
   socialProfiles Json? 

  address String

  referredBy String?

  meetingId Int?

  meeting Meeting? @relation(fields: [meetingId], references: [id])

  paymentScreenshot String?

  utrNumber String?

  status ApplicationStatus @default(PENDING)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("registration_applications")
}

model Admin {
  id Int @id @default(autoincrement())

  name String

  email String @unique

  password String

  phone String? @unique

  profilePhoto String?

  role String @default("ADMIN")

  status Status @default(ACTIVE)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@map("admins")
}

model RefreshToken {
  id Int @id @default(autoincrement())

  adminId Int

  token String @db.Text

  expiresAt DateTime

  isRevoked Boolean @default(false)

  admin Admin @relation(fields: [adminId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("refresh_tokens")
}

model Chapter {
  id Int @id @default(autoincrement())

  name  String
  city  String
  state String

  meetingDay  String
  meetingTime String

  address String

  status Status @default(ACTIVE)

  members      Member[]
  chapterRoles ChapterRole[]
  meetings     Meeting[]

  registrationApplications RegistrationApplication[] 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chapters")
}

model Member {
  id Int @id @default(autoincrement())

  chapterId Int

  memberCode String @unique

  firstName String
  lastName  String

  email    String  @unique
  password String?
  phone    String  @unique

  companyName      String
  profession       String
  businessCategory String

  website String?

  profilePhoto String?

  membershipStart  DateTime?
  membershipExpiry DateTime?

  status Status @default(PENDING)

  chapter Chapter @relation(fields: [chapterId], references: [id])

  chapterRoles ChapterRole[]

  visitorsReferred Visitor[] @relation("VisitorReferrer")

  meetingMembers MeetingMember[]

  referralsGiven Referral[] @relation("GivenReferrals")

  referralsReceived Referral[] @relation("ReceivedReferrals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("members")
}

model ChapterRole {
  id Int @id @default(autoincrement())

  chapterId Int
  memberId  Int

  role ChapterRoleType

  chapter Chapter @relation(fields: [chapterId], references: [id])

  member Member @relation(fields: [memberId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chapter_roles")
}

model Meeting {
  id Int @id @default(autoincrement())

  chapterId Int

  title String

  description String? @db.Text

  meetingDate DateTime

  startTime String
  endTime   String

  address String

  meetingFee Decimal? @db.Decimal(10, 2)

  agenda String? @db.Text

  status Status @default(ACTIVE)

  chapter         Chapter          @relation(fields: [chapterId], references: [id])
  meetingMembers  MeetingMember[]
  meetingVisitors MeetingVisitor[]

  registrationApplications RegistrationApplication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("meetings")
}

model Visitor {
  id Int @id @default(autoincrement())

  firstName String
  lastName  String?

  email String?
  phone String  @unique

  companyName      String?
  profession       String?
  businessCategory String?

  source VisitorSource

  status VisitorStatus @default(LEAD)

  referredByMemberId Int?

  notes String? @db.Text

  referredByMember Member?          @relation("VisitorReferrer", fields: [referredByMemberId], references: [id])
  meetingVisitors  MeetingVisitor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("visitors")
}

model MeetingMember {
  id Int @id @default(autoincrement())

  meetingId Int
  memberId  Int

  paymentStatus PaymentStatus @default(PENDING)

  paymentScreenshot String?

  utrNumber String?

  attendanceStatus AttendanceStatus?

  meeting Meeting @relation(fields: [meetingId], references: [id])
  member  Member  @relation(fields: [memberId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([meetingId, memberId])
  @@map("meeting_members")
}

model MeetingVisitor {
  id Int @id @default(autoincrement())

  meetingId Int
  visitorId Int

  paymentStatus PaymentStatus @default(PENDING)

  paymentScreenshot String?

  utrNumber String?

  attendanceStatus AttendanceStatus?

  meeting Meeting @relation(fields: [meetingId], references: [id])
  visitor Visitor @relation(fields: [visitorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([meetingId, visitorId])
  @@map("meeting_visitors")
}

model Referral {
  id Int @id @default(autoincrement())

  givenByMemberId Int

  receivedByMemberId Int

  title String

  description String? @db.Text

  referralValue Decimal? @db.Decimal(10, 2)

  isDeleted Boolean @default(false)

  status ReferralStatus @default(OPEN)

  givenByMember Member @relation("GivenReferrals", fields: [givenByMemberId], references: [id])

  receivedByMember Member @relation("ReceivedReferrals", fields: [receivedByMemberId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("referrals")
}
