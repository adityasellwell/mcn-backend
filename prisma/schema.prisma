generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model RegistrationApplication {
  id                Int               @id @default(autoincrement())
  registrationType  RegistrationType
  chapterName       String?
  fullName          String
  mobile            String
  email             String
  companyName       String
  businessCategory  String
  website           String?
  address           String
  referredBy        String?
  paymentScreenshot String?
  utrNumber         String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  status            ApplicationStatus @default(PENDING)
  meetingId         Int?
  socialProfiles    String?           @db.LongText
  chapterId         Int?
  chapter           Chapter?          @relation(fields: [chapterId], references: [id])
  meeting           Meeting?          @relation(fields: [meetingId], references: [id])

  @@index([chapterId], map: "registration_applications_chapterId_fkey")
  @@index([meetingId], map: "registration_applications_meetingId_fkey")
  @@map("registration_applications")
}

model Admin {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  role          String         @default("ADMIN")
  status        Status         @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  phone         String?        @unique
  profilePhoto  String?
  refreshTokens RefreshToken[]

  @@map("admins")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  adminId   Int
  token     String   @db.Text
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  admin     Admin    @relation(fields: [adminId], references: [id])

  @@index([adminId], map: "refresh_tokens_adminId_fkey")
  @@map("refresh_tokens")
}

model Chapter {
  id                       Int                       @id @default(autoincrement())
  name                     String
  city                     String
  state                    String
  meetingDay               String
  meetingTime              String
  status                   Status                    @default(ACTIVE)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  address                  String
  chapterRoles             ChapterRole[]
  meetings                 Meeting[]
  members                  Member[]
  registrationApplications RegistrationApplication[]

  @@map("chapters")
}

model Member {
  id                Int             @id @default(autoincrement())
  chapterId         Int
  memberCode        String          @unique
  firstName         String
  lastName          String
  email             String          @unique
  phone             String          @unique
  companyName       String
  profession        String
  businessCategory  String
  website           String?
  profilePhoto      String?
  membershipStart   DateTime?
  membershipExpiry  DateTime?
  status            Status          @default(PENDING)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  password          String?
  chapterRoles      ChapterRole[]
  meetingMembers    MeetingMember[]
  chapter           Chapter         @relation(fields: [chapterId], references: [id])
  referralsGiven    Referral[]      @relation("GivenReferrals")
  referralsReceived Referral[]      @relation("ReceivedReferrals")
  visitorsReferred  Visitor[]       @relation("VisitorReferrer")

  @@index([chapterId], map: "members_chapterId_fkey")
  @@map("members")
}

model ChapterRole {
  id        Int             @id @default(autoincrement())
  chapterId Int
  memberId  Int
  role      ChapterRoleType
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  chapter   Chapter         @relation(fields: [chapterId], references: [id])
  member    Member          @relation(fields: [memberId], references: [id])

  @@index([chapterId], map: "chapter_roles_chapterId_fkey")
  @@index([memberId], map: "chapter_roles_memberId_fkey")
  @@map("chapter_roles")
}

model Meeting {
  id                       Int                       @id @default(autoincrement())
  chapterId                Int
  title                    String
  description              String?                   @db.Text
  meetingDate              DateTime
  startTime                String
  endTime                  String
  address                  String
  meetingFee               Decimal?                  @db.Decimal(10, 2)
  agenda                   String?                   @db.Text
  status                   Status                    @default(ACTIVE)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  meetingMembers           MeetingMember[]
  meetingVisitors          MeetingVisitor[]
  chapter                  Chapter                   @relation(fields: [chapterId], references: [id])
  registrationApplications RegistrationApplication[]

  @@index([chapterId], map: "meetings_chapterId_fkey")
  @@map("meetings")
}

model Visitor {
  id                 Int              @id @default(autoincrement())
  firstName          String
  lastName           String?
  email              String?
  phone              String           @unique
  companyName        String?
  profession         String?
  businessCategory   String?
  source             VisitorSource
  status             VisitorStatus    @default(LEAD)
  referredByMemberId Int?
  notes              String?          @db.Text
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  meetingVisitors    MeetingVisitor[]
  referredByMember   Member?          @relation("VisitorReferrer", fields: [referredByMemberId], references: [id])

  @@index([referredByMemberId], map: "visitors_referredByMemberId_fkey")
  @@map("visitors")
}

model MeetingMember {
  id                Int               @id @default(autoincrement())
  meetingId         Int
  memberId          Int
  paymentStatus     PaymentStatus     @default(PENDING)
  paymentScreenshot String?
  utrNumber         String?
  attendanceStatus  AttendanceStatus?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  meeting           Meeting           @relation(fields: [meetingId], references: [id])
  member            Member            @relation(fields: [memberId], references: [id])

  @@unique([meetingId, memberId])
  @@index([memberId], map: "meeting_members_memberId_fkey")
  @@map("meeting_members")
}

model MeetingVisitor {
  id                Int               @id @default(autoincrement())
  meetingId         Int
  visitorId         Int
  paymentStatus     PaymentStatus     @default(PENDING)
  paymentScreenshot String?
  utrNumber         String?
  attendanceStatus  AttendanceStatus?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  meeting           Meeting           @relation(fields: [meetingId], references: [id])
  visitor           Visitor           @relation(fields: [visitorId], references: [id])

  @@unique([meetingId, visitorId])
  @@index([visitorId], map: "meeting_visitors_visitorId_fkey")
  @@map("meeting_visitors")
}

model Referral {
  id                 Int            @id @default(autoincrement())
  givenByMemberId    Int
  receivedByMemberId Int
  title              String
  description        String?        @db.Text
  referralValue      Decimal?       @db.Decimal(10, 2)
  status             ReferralStatus @default(OPEN)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  isDeleted          Boolean        @default(false)
  givenByMember      Member         @relation("GivenReferrals", fields: [givenByMemberId], references: [id])
  receivedByMember   Member         @relation("ReceivedReferrals", fields: [receivedByMemberId], references: [id])

  @@index([givenByMemberId], map: "referrals_givenByMemberId_fkey")
  @@index([receivedByMemberId], map: "referrals_receivedByMemberId_fkey")
  @@map("referrals")
}

enum Status {
  ACTIVE
  INACTIVE
  PENDING
}

enum ChapterRoleType {
  PRESIDENT
  VICE_PRESIDENT
  TREASURER
  SECRETARY
}

enum VisitorSource {
  ADMIN
  MEMBER
  WEBSITE
}

enum VisitorStatus {
  LEAD
  INVITED
  REGISTERED
  PAYMENT_SUBMITTED
  PAID
  ATTENDED
  CONVERTED
  REJECTED
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum RegistrationType {
  MEMBER
  GUEST
  VISITOR
  OTHER
}

enum ReferralStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}
